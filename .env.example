# ============================================================
# FitTracker v2 — Variables de entorno
# Copia este archivo a .env y completa los valores
# NUNCA subas .env al repositorio
# ============================================================

# ── ENTORNO ────────────────────────────────────────────────
ENVIRONMENT=development

# ── POSTGRESQL ─────────────────────────────────────────────
POSTGRES_PASSWORD=cambia_esta_password_segura

# ── SEGURIDAD INTERNA (Node ↔ Python) ──────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=genera_un_secreto_de_64_chars_hex

# ── LLM (RAG) ──────────────────────────────────────────────
# OpenAI — obtén tu clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,capacitor://localhost

# ── FEATURE FLAGS ──────────────────────────────────────────
# Cambiar a "true" para habilitar — cada feature tiene su propio flag
FEATURE_VISION_V2=false
FEATURE_RAG_ENABLED=false
FEATURE_WEEKLY_PDF=false
FEATURE_YOLO_ENABLED=false

# ── N8N AI AGENT ───────────────────────────────────────────
# URL del webhook en n8n (se obtiene al activar el workflow "FitTracker AI Coaching Agent")
# Formato: http://tu-n8n.com/webhook/fittracker-events
N8N_WEBHOOK_URL=

# Secreto compartido entre FitTracker y n8n (genera uno con: openssl rand -hex 32)
N8N_SECRET=

# URL pública del backend (para que n8n pueda llamar al callback)
# En desarrollo con ngrok: https://xxxx.ngrok.io
# En producción: https://api.tudominio.com
FITTRACKER_BACKEND_URL=http://localhost:3000

# API Key de Anthropic para el nodo Claude en n8n
# Se configura como variable de entorno en n8n, NO aquí
# Ver: n8n → Settings → Variables de entorno → ANTHROPIC_API_KEY

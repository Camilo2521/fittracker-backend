# FitTracker Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (primary)
DATABASE_URL=postgresql://postgres:PASSWORD@127.0.0.1:5432/fittracker

# SQLite fallback path (relative to backend/ working directory)
DB_PATH=../database/fittracker.db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate JWT_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_96_CHAR_HEX_STRING
JWT_ACCESS_EXPIRES=15m    # duración del access token (default: 15m)
JWT_REFRESH_DAYS=30       # duración del refresh token en días (default: 30)

# Shared secret between Node.js backend and Python service
# Must match INTERNAL_API_SECRET in python_service/.env
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# ── Python Microservice ───────────────────────────────────────────────────────
PYTHON_SERVICE_URL=http://localhost:8000

# ── CORS — comma-separated list of allowed origins ───────────────────────────
CORS_ORIGINS=http://localhost:8080,capacitor://localhost,ionic://localhost

# ── Local AI (Ollama) ─────────────────────────────────────────────────────────
# Install: winget install Ollama.Ollama  then: ollama pull llama3.2
# Recommended models: llama3.2 (2GB) | mistral (4GB) | phi4 (8GB) | gemma2 (5GB)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# ── Cloud AI (optional) ───────────────────────────────────────────────────────
# Only needed if you want Anthropic Claude as AI fallback
# ANTHROPIC_API_KEY=sk-ant-...

# ── Email (reset de contraseña) ───────────────────────────────────────────────
# Sin SMTP configurado, el link de reset se imprime en consola (modo desarrollo).
# Proveedores comunes:
#   Gmail:    SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  (requiere "App Password")
#   Outlook:  SMTP_HOST=smtp.office365.com  SMTP_PORT=587
#   Resend:   SMTP_HOST=smtp.resend.com  SMTP_PORT=465  SMTP_SECURE=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=FitTracker <noreply@fittracker.app>

# URL del frontend (para construir el enlace de reset)
FRONTEND_URL=http://localhost:5173

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_VISION_V2=false
FEATURE_RAG_ENABLED=false
FEATURE_WEEKLY_PDF=false

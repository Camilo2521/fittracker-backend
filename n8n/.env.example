# Copia este archivo como n8n/.env y rellena los valores reales.
# NUNCA subas n8n/.env a git.

# Clave API de Anthropic (console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Contraseña de PostgreSQL para la base de datos de n8n
DB_POSTGRESDB_PASSWORD=tu_password_aqui

# URL del backend FitTracker (por defecto: http://localhost:3000)
FITTRACKER_BACKEND_URL=http://localhost:3000

# Secreto para verificar webhooks entre n8n y el backend
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
N8N_SECRET=genera_un_secreto_aleatorio_aqui

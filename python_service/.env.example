# FitTracker Python Service — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
# Async driver (used by FastAPI / SQLAlchemy async sessions)
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@127.0.0.1:5432/fittracker

# Sync driver (used for Alembic migrations and sync queries)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:PASSWORD@127.0.0.1:5432/fittracker

# ── Security ──────────────────────────────────────────────────────────────────
# Must match INTERNAL_API_SECRET in backend/.env
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# ── YOLO pose/food detection ──────────────────────────────────────────────────
FEATURE_YOLO_ENABLED=false
# Path to the YOLOv8 model weights file (download: yolo export model=yolov8n-pose.pt)
YOLO_MODEL_PATH=yolov8n-pose.pt

# ── RAG / OpenAI ──────────────────────────────────────────────────────────────
FEATURE_RAG_ENABLED=false
# Only required when FEATURE_RAG_ENABLED=true
# OPENAI_API_KEY=sk-...
